datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  folders   Folder[]
}

model Folder {
  id        String   @id @default(uuid())
  name      String
  color     String   // e.g., 'blue', 'yellow', 'pink', 'purple'
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  notes     Note[]
}

model Note {
  id        String   @id @default(uuid())
  title     String
  status    String   // 'completed', 'continued', or 'backlog'
  items     String   // JSON-stringified array of checklist items
  folderId  String
  folder    Folder   @relation(fields: [folderId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
